# Database (required)
MONGODB_URI="mongodb://localhost:27017/clars_ai"
# Docker Compose: use host `mongo` from the app container, e.g. mongodb://mongo:27017/clars_ai
# (docker-compose.yml sets this automatically for the `app` service)

# --- Docker (optional) ---
# From repo root: `npm run docker:up` — set AUTH_SECRET in `.env` first.
# First run builds the Next.js image (often several minutes). Only app logs print; use `npm run docker:up:all` to see Mongo too.
# App: http://localhost:3000 · MongoDB on host port 27017

# NextAuth (required for login/signup – use AUTH_SECRET or NEXTAUTH_SECRET)
# Generate one with: npx auth secret   or   openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Resend (required for password reset emails – sign up at resend.com)
# The EMAIL_FROM domain must be verified in the Resend dashboard (e.g. noreply@yourdomain.com).
# For testing you can use Resend's default: onboarding@resend.dev
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# App URL (optional, for emails/links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Marketing / contact (optional)
NEXT_PUBLIC_CONTACT_EMAIL="hello@clars.ai"
# Footer social links — leave unset to hide icons and show “get in touch” instead
# NEXT_PUBLIC_SOCIAL_X_URL="https://x.com/yourhandle"
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL="https://linkedin.com/company/..."
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL="https://instagram.com/..."

# Admin dashboard: comma-separated emails (default: admin@clars.ai if unset)
# ADMIN_EMAILS="admin@clars.ai,you@company.com"

# Demo data reset (Settings → Demo data)
# Development: if empty, any signed-in user may seed. Production: disabled unless DEMO_SEED_ENABLED=true.
DEMO_SEED_ALLOWED_EMAILS=""
# DEMO_SEED_ENABLED="true"

# AI Assistant (optional — enable Chat, Email, Reports under /dashboard/ai)
# Priority order: OpenRouter → OpenAI → Gemini. Set whichever key you have.
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="openai/gpt-4o-mini"
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"
