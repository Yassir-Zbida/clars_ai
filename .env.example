# Database (required)
DATABASE_URL="postgresql://user:password@host:5432/clars_ai"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (optional, for magic link emails)
RESEND_API_KEY=""
EMAIL_FROM="noreply@clars.ai"

# App URL (optional, for emails/links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
