{
  "name": "clars-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "rm -rf .next",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "node scripts/run-jest.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "docker:build": "docker build -t clars-ai .",
    "docker:up": "docker compose up --build --attach app",
    "docker:up:all": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
